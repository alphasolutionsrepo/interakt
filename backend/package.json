{
  "name": "interakt",
  "version": "0.1.1",
  "private": true,
  "license": "MIT",
  "description": "AI-powered search and chat platform — admin dashboard and REST APIs (Next.js, Drizzle, Postgres + Elasticsearch / Azure AI Search).",
  "author": "Alpha Solutions",
  "repository": {
    "type": "git",
    "url": "https://github.com/alphasolutionsrepo/interakt.git",
    "directory": "backend"
  },
  "homepage": "https://github.com/alphasolutionsrepo/interakt#readme",
  "bugs": "https://github.com/alphasolutionsrepo/interakt/issues",
  "keywords": [
    "search",
    "chat",
    "ai",
    "rag",
    "elasticsearch",
    "azure-ai-search",
    "vector-search",
    "agentic",
    "nextjs"
  ],
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "scripts": {
    "widgets:install": "npm --prefix widgets install --include=dev --silent --no-fund --no-audit --prefer-offline",
    "widgets:build": "npm --prefix widgets run build",
    "widgets:watch": "npm --prefix widgets run dev",
    "predev": "npm run widgets:install && npm run widgets:build",
    "dev": "next dev",
    "prebuild": "npm run widgets:install && npm run widgets:build",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "lint:strict": "eslint --max-warnings=0 .",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "db:generate": "node scripts/db-migrate.js generate",
    "db:migrate": "node scripts/db-migrate.js apply",
    "db:generate-analytics": "node scripts/db-migrate-analytics.js generate",
    "db:migrate-analytics": "node scripts/db-migrate-analytics.js apply",
    "db:migrate-all": "npm run db:generate && npm run db:migrate && npm run db:generate-analytics && npm run db:migrate-analytics",
    "openapi:generate": "tsx src/features/public-api/generate-openapi.ts",
    "infra:up": "docker compose -f docker/docker-compose.dev.yml up -d --wait",
    "infra:down": "docker compose -f docker/docker-compose.dev.yml down",
    "infra:reset": "docker compose -f docker/docker-compose.dev.yml down -v",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
