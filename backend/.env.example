# ─────────────────────────────────────────────────────────────────────────────
# Interakt backend — local dev defaults.
# Copy to .env and fill in the secrets marked <...>.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
LOG_RAW_RESULTS=true
ENABLE_FILE_LOGGING=true
ENABLE_OTEL=true

# Generate with: openssl rand -base64 32
AUTH_SECRET=<generate-with-openssl-rand-base64-32>
AUTH_TRUST_HOST=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=<generate-with-openssl-rand-base64-32>

# Generate with: openssl rand -hex 32
SECRETS_ENCRYPTION_KEY=<generate-with-openssl-rand-hex-32>

# Set explicitly because Vercel sets NODE_ENV=production even on preview deploys.
ANALYTICS_ENV=development

# ── Postgres (local docker stack: `npm run infra:up`) ───────────────────────
POSTGRES_URL='postgresql://postgres:postgres@localhost:5432/interakt'
ANALYTICS_POSTGRES_URL='postgresql://postgres:postgres@localhost:5432/interakt_analytics'

# To use a managed/remote Postgres instead, comment the two lines above and
# point these at your endpoint (e.g. a cloud Postgres with TLS):
# POSTGRES_URL='postgresql://<user>:<password>@<your-postgres-host>:5432/interakt?sslmode=require'
# ANALYTICS_POSTGRES_URL='postgresql://<user>:<password>@<your-postgres-host>:5432/interakt_analytics?sslmode=require'

# ── Elasticsearch (local docker stack, no auth) ─────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200/
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_SSL_ENABLED=false
ELASTICSSEARCH_API_KEY=

# To use a managed/remote Elasticsearch instead, comment the block above
# and point these at your endpoint:
# ELASTICSEARCH_URL=https://<your-elasticsearch-host>/
# ELASTICSEARCH_USERNAME=
# ELASTICSEARCH_PASSWORD=
# ELASTICSEARCH_SSL_ENABLED=true
# ELASTICSSEARCH_API_KEY=<your-elasticsearch-api-key>
# Only if your ES endpoint uses a self-signed cert (insecure — dev only):
# NODE_TLS_REJECT_UNAUTHORIZED=0

# ── AI providers ─────────────────────────────────────────────────────────────
# This is the ONE place to put your OpenAI key. The Demo Setup page
# (/admin/setup-demo) reads it from here, attaches it to the OpenAI provider, and
# sets OpenAI as the default for chat + embeddings. Hybrid search needs it to
# embed the demo catalog.
OPENAI_API_KEY=<your-openai-api-key>

# Ollama (optional — only if you want local models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=30000
OLLAMA_RETRIES=3
NEXT_PUBLIC_OLLAMA_BASE_URL=http://localhost:11434/

# ── Azure Search (optional fallback for semantic search) ─────────────────────
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_SEARCH_API_KEY=<get-from-azure-portal>

# ── Tavily (web search for RAG) ──────────────────────────────────────────────
TAVILY_API_KEY=<your-tavily-key>

# First-time demo setup:
#   1. npm run infra:up          # Postgres + Elasticsearch
#   2. set OPENAI_API_KEY above
#   3. cp setup/setup.config.example.yaml setup/setup.config.yaml  # admin login
#   4. npm run dev, then open /admin/setup-demo and click "Set up demo"
# The demo is declared in setup/data/demo.manifest.yaml (also your manual-setup
# reference). The page's "Reset" button tears it down for a clean rebuild.
