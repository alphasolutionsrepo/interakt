{
  "compilerOptions": {
    "paths": {
      "@/components/ui/*": [
        "./src/shared/ui/components/*"
      ],
      "@/components/custom/*": [
        "./src/shared/ui/custom/*"
      ],
      "@/lib/utils": [
        "./src/shared/utils/index.ts"
      ],
      "@/shared/utils/*": [
        "./src/shared/utils/*"
      ],
      "@/hooks/*": [
        "./src/shared/hooks/*"
      ],
      "@/shared/*": [
        "./src/shared/*"
      ],
      "@/features/*": [
        "./src/features/*"
      ],
      "@/app/*": [
        "./src/app/*"
      ],
      "@/config": [
        "./config/index.ts"
      ],
      "@/config/*": [
        "./config/*"
      ],
      "@/db/*": [
        "./db/*"
      ]
    },
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "scripts",
    "widgets"
  ]
}
